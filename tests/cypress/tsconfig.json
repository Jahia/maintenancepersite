{
	"extends": "../tsconfig.json",
	"include": ["**/*.ts", "support/e2e.js", "plugins/index.js"],
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"noEmit": true,
		"isolatedModules": false,
		"types": ["cypress", "node", "@jahia/cypress"],
		"lib": ["es2018", "dom"],
		"target": "es2018",
		"module": "esnext",
		"moduleResolution": "bundler"
	}
}
